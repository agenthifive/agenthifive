# Integration Testing Environment
# All services run in Docker — URLs use container hostnames

# Database
DATABASE_URL=postgresql://agenthifive:test-password@postgres:5432/agenthifive_test

# Web (Next.js — running in container)
NEXT_PUBLIC_WEB_URL=http://localhost:3100
NEXT_PUBLIC_API_URL=http://localhost:8180/v1
NEXT_PUBLIC_DOCS_URL=/docs
WEB_INTERNAL_URL=http://web:3000

# Better Auth
BETTER_AUTH_SECRET=integration-test-secret-not-for-production

# API (Fastify — running in container)
API_PORT=4000
WEB_URL=http://web:3000
WEB_JWKS_URL=http://web:3000/.well-known/jwks.json

# Encryption key (64 hex chars = 32 bytes for AES-256-GCM)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Social Login (Better Auth) — test/mock credentials
AUTH_GOOGLE_CLIENT_ID=test-auth-google-client-id
AUTH_GOOGLE_CLIENT_SECRET=test-auth-google-client-secret
AUTH_MICROSOFT_CLIENT_ID=test-auth-microsoft-client-id
AUTH_MICROSOFT_CLIENT_SECRET=test-auth-microsoft-client-secret
AUTH_MICROSOFT_TENANT_ID=test-tenant-id

# Connection credentials (test/mock)
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
MICROSOFT_CLIENT_ID=test-microsoft-client-id
MICROSOFT_CLIENT_SECRET=test-microsoft-client-secret
MICROSOFT_TENANT_ID=test-tenant-id
TELEGRAM_BOT_TOKEN=test-telegram-bot-token

# Agent Auth (private_key_jwt)
AGENT_TOKEN_AUDIENCE=http://api:4000
AGENT_TOKEN_TTL_SECONDS=900

# SSRF: allow Docker-internal hostnames for Model B proxy tests (never set in production)
SSRF_ALLOWLIST_HOSTS=echo
