{
  "name": "@agenthifive/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts --env-file=../../.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --import ./dist/instrument.js dist/server.js",
    "lint": "echo Lint: OK",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "drizzle-kit push",
    "migrate-apply": "drizzle-kit migrate",
    "migrate-generate": "drizzle-kit generate",
    "migrate-push": "drizzle-kit push",
    "migrate-studio": "drizzle-kit studio",
    "test": "DATABASE_URL=postgresql://test:test_password@localhost:5433/agenthifive_test node --experimental-test-module-mocks --import tsx --test --test-concurrency=1 --test-force-exit 'src/__tests__/**/*.test.ts'",
    "test:integration": "DATABASE_URL=postgresql://test:test_password@localhost:5433/agenthifive_test node --experimental-test-module-mocks --import tsx --test --test-concurrency=1 --test-force-exit 'src/integration/**/*.test.ts'",
    "test:watch": "DATABASE_URL=postgresql://test:test_password@localhost:5433/agenthifive_test node --experimental-test-module-mocks --import tsx --test --test-concurrency=1 --watch 'src/__tests__/**/*.test.ts'",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "test:db:reset": "docker compose -f docker-compose.test.yml down -v && docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:logs": "docker compose -f docker-compose.test.yml logs -f postgres-test"
  },
  "dependencies": {
    "@agenthifive/contracts": "workspace:*",
    "@agenthifive/oauth-connectors": "workspace:*",
    "@agenthifive/security": "workspace:*",
    "@azure/communication-email": "^1.1.0",
    "@better-auth/expo": "^1.4.19",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.5",
    "@sentry/node": "^10.45.0",
    "better-auth": "^1.4.19",
    "drizzle-orm": "^0.45.1",
    "expo-server-sdk": "^3.15.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "imapflow": "^1.2.18",
    "jose": "^6.2.3",
    "libphonenumber-js": "^1.12.37",
    "mailparser": "^3.9.6",
    "nodemailer": "^8.0.1",
    "oauth4webapi": "^3.3.0",
    "postgres": "^3.4.0",
    "undici": "^7.21.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "drizzle-kit": "^0.31.8",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
